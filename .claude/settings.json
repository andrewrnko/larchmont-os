{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm install *)",
      "Bash(npm run lint)",
      "Bash(npx *)",
      "Read(*)",
      "Write(src/**)",
      "Write(app/**)",
      "Write(lib/**)",
      "Write(components/**)",
      "Write(public/**)",
      "Write(.env.local)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Write(node_modules/**)",
      "Write(.git/**)",
      "Write(package-lock.json)"
    ]
  }
}
